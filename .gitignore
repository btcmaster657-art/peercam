# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ── desktop ───────────────────────────────────────────────────────────────────
# dependencies
/desktop/node_modules

# compiled renderer + main output
/desktop/dist

# electron-builder output
/desktop/release

# native addon build output
/desktop/native/build

# compiled object files and linker artifacts next to source
/desktop/native/*.obj
/desktop/native/*.lib
/desktop/native/*.exp

# DirectShow filter build artifacts (keep source, ignore compiled output)
/desktop/native/vcam_filter/*.obj
/desktop/native/vcam_filter/*.lib
/desktop/native/vcam_filter/*.exp
/desktop/native/vcam_filter/*.dll

# BaseClasses — downloaded at build time, not committed
/desktop/native/baseclasses

# ── public downloads ──────────────────────────────────────────────────────────
# Built installers are deployed via Vercel, not committed to git
/public/downloads/*.AppImage
/public/downloads/*.dmg
/public/downloads/*.deb
